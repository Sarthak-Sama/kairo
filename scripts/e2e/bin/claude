#!/usr/bin/env node
/**
 * Stub Claude Code CLI for Kairo end-to-end pipeline testing.
 *
 * Implements the interface Kairo's adapter calls:
 *   claude -p --permission-mode <mode> --model <model>
 * with the prompt on stdin and the repo root as cwd.
 *
 * It actually edits a file in the repo (so Kairo's git diff capture is real)
 * and prints a well-formed phase report. Invocations are logged to
 * $KAIRO_E2E_STATE_DIR/claude-log.ndjson.
 */
import fs from 'node:fs';
import path from 'node:path';

const stateDir = process.env.KAIRO_E2E_STATE_DIR;
if (!stateDir) {
  console.error('stub claude: KAIRO_E2E_STATE_DIR not set');
  process.exit(2);
}

// Print transport pipes the prompt on stdin; PTY transport passes it as the
// argv element after -p (real `claude --print` refuses TTY stdin).
const argvAfterP = process.argv[2] === '-p' ? process.argv[3] : undefined;
const prompt =
  argvAfterP !== undefined && !argvAfterP.startsWith('-') ? argvAfterP : fs.readFileSync(0, 'utf8');
const phaseMatch = prompt.match(/## Phase (\d+) instructions/);
const phase = phaseMatch ? Number(phaseMatch[1]) : 1;
const isRevision = prompt.includes('This is a REVISION request');

// Head-role support: when Claude is the agency head, triage/review prompts
// arrive here and must be answered with directives (canonical role-neutral
// form), never with file edits.
function headDirective(obj, prose) {
  const full = {
    actor: 'head',
    requiresUserInput: false,
    risk: 'low',
    reason: 'stub reason',
    successCriteria: [],
    checksToRun: ['test'],
    ...obj,
  };
  return `${prose}\n\n\`\`\`json\n${JSON.stringify(full, null, 2)}\n\`\`\``;
}

const role = prompt.includes('classify the task')
  ? 'head-triage'
  : prompt.includes('reviewing an implementation phase')
    ? 'head-review'
    : 'development';

fs.appendFileSync(
  path.join(stateDir, 'claude-log.ndjson'),
  JSON.stringify({ argv: process.argv.slice(2), role, phase, isRevision, cwd: process.cwd() }) + '\n',
);

if (role === 'head-triage') {
  // If the operator locked a lane, the prompt says so; otherwise the head
  // classifies. The lane_copy_classify scenario expects a copy classification.
  const laneLocked = prompt.includes('operator-selected');
  const classifiesCopy = process.env.KAIRO_E2E_SCENARIO === 'lane_copy_classify';
  console.log(headDirective(
    {
      action: 'delegate_to_development_lead',
      taskClass: 'single_phase_dev_lead',
      phase: 1,
      reason: 'feature work suits delegation',
      instructions: 'Create src/feature.txt containing a greeting line.',
      // Echo back nothing when locked (Kairo keeps the operator lane); else classify.
      ...(laneLocked ? {} : { lane: classifiesCopy ? 'copy' : 'feature' }),
    },
    '## Master Plan\nOne phase: create the feature file via the development lead.',
  ));
  process.exit(0);
}
if (role === 'head-review') {
  console.log(headDirective(
    { action: 'declare_complete', reason: 'implementation matches the plan and checks pass' },
    'Reviewed the diff against the plan. No blockers.',
  ));
  process.exit(0);
}

// Slow-development scenario: print partial output, record our PID, then hang
// until killed — used to test in-flight cancellation of an owned child.
if (process.env.KAIRO_E2E_SCENARIO === 'slow_dev') {
  const featurePath0 = path.join(process.cwd(), 'src', 'feature.txt');
  fs.mkdirSync(path.dirname(featurePath0), { recursive: true });
  fs.appendFileSync(featurePath0, 'partial work before cancellation\n');
  process.stdout.write('PARTIAL: started implementing, this will take a while...\n');
  fs.writeFileSync(path.join(stateDir, 'slow-dev-pid'), String(process.pid));
  setInterval(() => {}, 1000); // hang until killed
} else {
// Make a real change in the working tree.
const featurePath = path.join(process.cwd(), 'src', 'feature.txt');
fs.mkdirSync(path.dirname(featurePath), { recursive: true });
fs.appendFileSync(featurePath, `hello from stub claude (phase ${phase}${isRevision ? ', revision' : ''})\n`);

console.log(`Working on phase ${phase}...

# Phase ${phase} Report
## Changed Files
- src/feature.txt
## Commands Run
- (none)
## Risks
none
## Phase Complete
yes — feature file ${isRevision ? 'revised' : 'created'} per instructions`);
}
